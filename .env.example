PORT=3010

# Custom API key for client authentication
# Set this to a simple key so you don't need to pass the long Cursor cookie every time
# Example: AUTH_TOKEN=sk-my-secret-key
AUTH_TOKEN=

# Cursor cookie (JWT token) for backend API calls
# Get this from Cursor IDE via packet capture or `npm run login`
CURSOR_COOKIE=

# HTTP proxy (optional)
# PROXY_URL=http://127.0.0.1:7890
